configuration {
    modi: "drun,run";
    show-icons: false;
    drun-display-format: "{name}";
}

@theme "~/.local/state/loom/generated/rofi-theme.rasi"

window {
    background-color: @bg;
    border: 2px;
    border-color: @border;
    border-radius: @radius;
    width: @win-width;
    padding: @pad;
}

mainbox {
    background-color: @bg;
    spacing: @elem-spacing;
    children: [ inputbar, listview ];
}

inputbar {
    background-color: @bg-alt;
    text-color: @fg;
    padding: @pad;
    spacing: @elem-spacing;
    children: [ prompt, entry ];
}

prompt {
    background-color: inherit;
    text-color: @accent;
}

entry {
    background-color: inherit;
    text-color: @fg;
    placeholder-color: @fg-muted;
}

listview {
    background-color: @bg;
    lines: @lines;
    columns: 1;
    fixed-height: false;
    dynamic: true;
    scrollbar: false;
    spacing: @elem-spacing;
}

element {
    background-color: @bg;
    text-color: @fg;
    padding: @pad;
    spacing: @elem-spacing;
    border: 0px;
    border-radius: @radius;
}

element selected {
    background-color: @selection-bg;
    text-color: @selection-fg;
    border-radius: @radius;
}

element-text {
    background-color: inherit;
    text-color: inherit;
    vertical-align: 0.5;
}

element-icon {
    size: @icon-size;
    background-color: inherit;
}
