# nvim command allows for remote cmd execution from loom
PMUX_EDITOR_CMD='exec nvim --listen "/tmp/nvim-loom-$$-$(date +%s).sock" .'
PMUX_SHELL_CMD='exec "$SHELL" -l'
PMUX_CHOOSER_CMD='fzf --prompt="Project > "'

PMUX_FIXED_PROJECTS=(
    "$HOME/.dotfiles"
)

PMUX_PROJECT_ROOTS=(
    "$HOME/repos"
    "$HOME/work"
)
