sunshine/.config/sunshine/credentials/
sunshine/.config/sunshine/sunshine_state.json
sunshine/.config/sunshine/sunshine.log
nvim/.config/nvim/lazy-lock.json

# binaries
scripts/.local/bin/loom
scripts/.local/bin/pmux
scripts/.local/bin/pmux-run
scripts/.local/bin/pmux-cheat
scripts/.local/bin/decepticon

# user-local install pointers — version-pinned absolute symlinks that
# auto-update on every release. They aren't portable across machines
# and they're what historically blocked stow from cleanly folding
# scripts/.local/bin/ (stow rejects absolute symlinks in package
# sources, aborting any sibling-tree analysis).
scripts/.local/bin/claude
scripts/.local/bin/python3.11
scripts/.local/bin/uv
scripts/.local/bin/uvx
scripts/.local/bin/spotdl

# Generated at runtime by hyprland-hyprpaper wrapper — conflicts with stow
hyprland/.config/hypr/hyprpaper-generated.conf

# Hyprland helper symlinks. Bootstrap symlinks each hyprland/.local/bin/*
# into ~/.local/bin/, which is itself a symlink to scripts/.local/bin/,
# so they land here at install time. Canonical sources live in
# hyprland/.local/bin/ (committed); these are absolute-path machine-
# specific symlinks and don't belong in version control.
scripts/.local/bin/start-hyprland
scripts/.local/bin/hyprland-cursor
scripts/.local/bin/hyprland-float-toggle
scripts/.local/bin/hyprland-monocle
scripts/.local/bin/hyprland-output
scripts/.local/bin/hyprland-output-profile
scripts/.local/bin/hyprland-wallpaper
scripts/.local/bin/hyprland-ws
scripts/.local/bin/hyprland-ws-migrate
scripts/.local/bin/httpx
scripts/.local/bin/nuclei
