XF86AudioRaiseVolume
    pactl set-sink-volume @DEFAULT_SINK@ +5%

XF86AudioLowerVolume
    pactl set-sink-volume @DEFAULT_SINK@ -5%

XF86MonBrightnessUp
    ~/.local/bin/dwmblocks/brightness up

XF86MonBrightnessDown
    ~/.local/bin/dwmblocks/brightness down

super + shift + s
    flameshot gui

super + t
    python3 ~/repos/loom/loom menu
