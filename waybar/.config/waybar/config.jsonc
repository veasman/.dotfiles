// waybar тАФ ~/.config/waybar/config.jsonc
//
// Glyphs written as JSON \u escapes so source + on-disk bytes are
// always readable ASCII and waybar's JSON parser resolves them to
// the right codepoints at read time.
{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 4,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    // No `output` filter тАФ waybar renders on whatever outputs are
    // currently connected. Docked: all three externals. Undocked:
    // just eDP-1. Hotplug is handled automatically.

    "modules-left":   ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right":  ["memory", "custom/claude", "pulseaudio", "custom/network", "battery", "clock"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        // Show leading number (workspaces are named "<N>:<output>").
        "format": "{index}"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">яИЫ {}</span>"
    },

    "sway/window": {
        "max-length": 70,
        "tooltip": false
    },

    "clock": {
        // яБ│ = calendar (cleaner than clock-o at bar size)
        "format": "яБ│ {:%a %d %b %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        // яЛЫ = microchip
        "format": "яЛЫ {usage}%",
        "tooltip": false,
        "interval": 2
    },

    "memory": {
        // яФ╕ = md-memory (RAM-stick look). Falls back to яЗА
        // database if the glyph isn't mapped in the installed font.
        "states":         { "warning": 75, "critical": 90 },
        "format": "яИ│ {}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
        "interval": 5
    },

    "custom/claude": {
        // Claude 5-hour session utilization, via ~/.local/bin/claude-usage.
        // The script already prefixes its own nerd-font robot glyph and
        // "{pct}%" text, so format is just {}.
        "format": "{}",
        "exec": "claude-usage",
        "interval": 30,
        "tooltip": false
    },

    "custom/network": {
        "exec": "waybar-network",
        "return-type": "json"
    },

    "battery": {
        "states":          { "warning": 30, "critical": 15 },
        // Ramp icons тАФ pick changes with charge level.
        "format":          "{icon} {capacity}%",
        "format-charging": "яЗж {capacity}%",
        "format-plugged":  "яЗж {capacity}%",
        "format-full":     "яЙА {capacity}%",
        "format-icons":    ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
        "tooltip-format":  "{timeTo} ({power}W)"
    },

    "pulseaudio": {
        // Reactive icons тАФ glyph swaps with volume level. {icon} picks
        // from format-icons.default based on (volume / (max/len)).
        "format":           "{icon} {volume}%",
        "format-muted":     "яАж muted",
        "format-bluetooth": "яКУ {volume}%",
        "format-icons": {
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click":         "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right":   "kara-toe-client --app-id=pulsemixer -e pulsemixer",
        "scroll-step": 5
    }
}
