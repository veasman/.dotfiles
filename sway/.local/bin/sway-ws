#!/usr/bin/env sh
# sway-ws — per-output workspace switcher.
#
# Each output has its own independent 1-9, keyed by "<N>:<output_name>"
# (e.g. "1:DVI-I-1", "1:DP-2"). mod+1 on the center monitor shows
# 1:DVI-I-1; mod+1 on the left portrait shows 1:DVI-I-2. Mirrors kara's
# `sync_workspaces false` model.
#
# Usage:
#   sway-ws switch <1-9>    focus workspace N on the currently focused output
#   sway-ws move   <1-9>    move focused container to workspace N on current output

set -eu

if [ "$#" -lt 2 ]; then
    echo "usage: sway-ws switch|move <1-9>" >&2
    exit 2
fi
action="$1"
n="$2"

out=$(swaymsg -t get_outputs --raw | jq -r '.[] | select(.focused) | .name')
if [ -z "$out" ] || [ "$out" = "null" ]; then
    echo "sway-ws: no focused output" >&2
    exit 1
fi

ws="${n}:${out}"

case "$action" in
    switch) exec swaymsg workspace "$ws" ;;
    move)   exec swaymsg move container to workspace "$ws" ;;
    *)      echo "sway-ws: unknown action '$action' (expected switch|move)" >&2; exit 2 ;;
esac
