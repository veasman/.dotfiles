#!/usr/bin/env sh
# sway-scratchpad-ws — toggle a named "overlay" workspace the way
# kara's scratchpads worked.
#
# A scratchpad is just a dedicated sway workspace that we treat
# specially: preset windows live there permanently, and this helper
# toggles focus to/from it on whichever output is currently focused.
#
# First toggle (or first toggle after every preset window has closed)
# lazily autostarts the workspace's preset windows. This matches
# kara's `autostart` block inside its `scratchpad "<name>"` stanzas.
#
# Sway has no native per-workspace dim or blur, so there is no
# overlay effect under the scratchpad — the scratchpad is its own
# full-screen workspace.
#
# Usage: sway-scratchpad-ws toggle <workspace-name>
#   where <workspace-name> is one of: __scratch_main__, __scratch_music__

set -eu

autostart() {
    case "$1" in
        __scratch_main__)
            # Kara's main scratchpad: glances + TODO.md editor.
            setsid -f kara-toe-client --app-id=scratch-main-glances glances \
                >/dev/null 2>&1 || true
            setsid -f kara-toe-client --app-id=scratch-main-todo \
                nvim "$HOME/.dotfiles/personal/TODO.md" \
                >/dev/null 2>&1 || true
            ;;
        __scratch_music__)
            # Kara's music scratchpad: spotatui in a persistent tmux
            # session so it survives compositor restarts.
            setsid -f kara-toe-client --app-id=spotatui \
                tmux new-session -A -s spotify spotatui \
                >/dev/null 2>&1 || true
            ;;
        *)
            return 0
            ;;
    esac
}

cmd=${1:-}
ws=${2:-}

[ "$cmd" = "toggle" ] || { echo "usage: $(basename "$0") toggle <workspace>" >&2; exit 1; }
[ -n "$ws" ] || { echo "usage: $(basename "$0") toggle <workspace>" >&2; exit 1; }

state_dir="${XDG_RUNTIME_DIR:-/tmp}/sway-scratchpad-ws"
mkdir -p "$state_dir"
sanitized=$(printf '%s' "$ws" | sed 's/[^A-Za-z0-9]/_/g')
state_file="$state_dir/last-$sanitized"

current_ws=$(swaymsg -t get_workspaces | jq -r '.[] | select(.focused) | .name')

if [ "$current_ws" = "$ws" ]; then
    # Second toggle — return to the workspace we came from.
    if [ -s "$state_file" ]; then
        back=$(cat "$state_file")
        swaymsg "workspace $back" >/dev/null
    fi
    exit 0
fi

# First toggle — record origin, lazily autostart if empty, switch.
printf '%s' "$current_ws" > "$state_file"

# Count tiled + floating windows on the target workspace. 0 means
# either the workspace doesn't exist yet, or every preset closed
# since the last autostart — respawn in either case.
has_windows=$(swaymsg -t get_tree | jq --arg ws "$ws" '
    [ .. | objects
      | select(.type == "workspace" and .name == $ws)
      | .. | objects
      | select((.type == "con" or .type == "floating_con")
               and ((.nodes // []) | length == 0)
               and ((.floating_nodes // []) | length == 0))
      | .id
    ] | length')

if [ "${has_windows:-0}" -eq 0 ]; then
    autostart "$ws"
fi

focused_output=$(swaymsg -t get_outputs | jq -r '.[] | select(.focused) | .name')
# Switch to the scratchpad and pin it to the output the user was
# looking at. If the workspace already lived on a different output
# (e.g. because it was first created there), this drags it over.
swaymsg "workspace $ws; move workspace to output $focused_output" >/dev/null
