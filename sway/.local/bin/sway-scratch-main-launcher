#!/usr/bin/env sh
# sway-scratch-main-launcher — set up the main scratchpad's tmux
# session (kara parity: glances + TODO.md, side-by-side panes).
#
# The session is idempotent: if it already exists (e.g. the user
# closed the kara-toe-client window but the tmux server is still
# running), we just attach and keep the existing panes.
#
# Invoked from sway config as the command arg to kara-toe-client, so
# the terminal window embeds this tmux session.

set -eu

session=scratch-main

if ! tmux has-session -t "$session" 2>/dev/null; then
    tmux new-session -d -s "$session" glances
    tmux split-window -h -t "$session" "nvim '$HOME/.dotfiles/personal/TODO.md'"
fi

exec tmux attach -t "$session"
