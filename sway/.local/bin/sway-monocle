#!/usr/bin/env sh
# sway-monocle — kara-style monocle via native sway fullscreen.
#
# The focused window is fullscreened; every other window on the
# workspace stays in its tile position but is hidden by the
# fullscreen. Cycling swaps fullscreen to a different window atomically
# in a single swaymsg IPC call — near-instant, no hidden workspace,
# no waybar pollution.
#
# Actions:
#   toggle       enter/exit monocle (toggle fullscreen on focused)
#   cycle-next   focus next leaf; if fullscreen is on, move it along
#   cycle-prev   ditto, reverse
#   is-active    exit 0 if focused window is fullscreened

set -eu

current_ws() {
    # Sway's `get_tree` workspace objects don't carry a reliable
    # `.focused` field, so look the focused workspace up from
    # get_workspaces (same approach sway-focus-cycle uses).
    swaymsg -t get_workspaces | jq -r '.[] | select(.focused) | .name'
}

focused_info() {
    # Emit: "<id> <fullscreen_mode>"
    swaymsg -t get_tree | jq -r '
        [.. | objects
         | select(.focused == true and (.type == "con" or .type == "floating_con"))]
        | first
        | if . then "\(.id) \(.fullscreen_mode // 0)" else "" end'
}

leaves_on_ws() {
    ws="$1"
    swaymsg -t get_tree | jq -r --arg ws "$ws" '
        [.. | objects | select(.type == "workspace" and .name == $ws)][0]
        | if . then
            [.. | objects
             | select((.type == "con" or .type == "floating_con")
                      and ((.nodes // []) | length == 0)
                      and ((.floating_nodes // []) | length == 0))
             | .id]
          else [] end
        | .[]'
}

target_id() {
    direction="$1"
    focused="$2"
    ws=$(current_ws)
    [ -n "$ws" ] || return 1
    ids=$(leaves_on_ws "$ws")
    count=$(printf '%s\n' "$ids" | grep -c . || true)
    [ "$count" -gt 1 ] || return 1

    # 1-based index of focused window in the ordered list.
    idx=$(printf '%s\n' "$ids" | awk -v f="$focused" '$0 == f { print NR; exit }')
    [ -n "$idx" ] || return 1

    case "$direction" in
        next) t=$(( idx % count + 1 )) ;;
        prev) t=$(( (idx - 2 + count) % count + 1 )) ;;
    esac
    printf '%s\n' "$ids" | sed -n "${t}p"
}

action="${1:-toggle}"
case "$action" in
    toggle)
        swaymsg fullscreen toggle >/dev/null
        ;;
    cycle-next|cycle-prev)
        info=$(focused_info)
        [ -n "$info" ] || exit 1
        focused_id=${info% *}
        fs_mode=${info#* }
        direction=${action#cycle-}

        target=$(target_id "$direction" "$focused_id") || exit 1
        if [ "$fs_mode" = "0" ]; then
            # Not in monocle — just cycle focus to the next leaf.
            swaymsg "[con_id=$target] focus" >/dev/null
        else
            # Monocle active: atomic fullscreen swap in one IPC call.
            swaymsg "[con_id=$focused_id] fullscreen disable; [con_id=$target] focus; [con_id=$target] fullscreen enable" >/dev/null
        fi
        ;;
    is-active)
        info=$(focused_info)
        [ -n "$info" ] || exit 1
        fs_mode=${info#* }
        [ "$fs_mode" != "0" ]
        ;;
    *)
        echo "usage: sway-monocle {toggle|cycle-next|cycle-prev|is-active}" >&2
        exit 2
        ;;
esac
