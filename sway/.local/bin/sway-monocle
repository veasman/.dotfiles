#!/usr/bin/env sh
# sway-monocle — kara-style monocle via native sway fullscreen.
#
# The focused window is fullscreened; every other window on the
# workspace stays in its tile position but is hidden by the
# fullscreen. Cycling swaps fullscreen to a different window atomically
# in a single swaymsg IPC call, so it's near-instant — no window-move
# IPC churn, no hidden workspace on the sway tree, no waybar
# pollution from `__mono_*__` workspaces.
#
# Actions:
#   toggle       enter/exit monocle (toggle fullscreen on focused)
#   cycle-next   focus next leaf; if fullscreen is on, move it along
#   cycle-prev   ditto, reverse
#   is-active    exit 0 if focused window is fullscreened
#
# "Leaf" = any tiled or floating container with no child nodes. Sway's
# `focus next sibling` walks the tree shallowly and misses deep
# autotiling layouts, so we enumerate leaves from get_tree ourselves.

set -eu

focused_info() {
    # Emit: "<id> <fullscreen_mode>"
    swaymsg -t get_tree | jq -r '
        [.. | objects
         | select(.focused == true and (.type == "con" or .type == "floating_con"))]
        | first
        | if . then "\(.id) \(.fullscreen_mode // 0)" else "" end'
}

leaves_on_current_ws() {
    swaymsg -t get_tree | jq -r '
        [.. | objects | select(.type == "workspace" and .focused == true)]
        | first
        | [.. | objects
           | select((.type == "con" or .type == "floating_con")
                    and ((.nodes // []) | length == 0)
                    and ((.floating_nodes // []) | length == 0))
           | .id]
        | .[]'
}

target_id() {
    direction="$1"
    focused="$2"
    ids=$(leaves_on_current_ws) || return 1
    count=$(printf '%s\n' "$ids" | grep -c . || echo 0)
    [ "$count" -gt 1 ] || return 1

    # Determine focused's 0-based index in the list.
    focused_idx=-1
    i=0
    for id in $ids; do
        if [ "$id" = "$focused" ]; then
            focused_idx=$i
        fi
        i=$((i + 1))
    done
    [ "$focused_idx" -ge 0 ] || return 1

    case "$direction" in
        next) t=$(( (focused_idx + 1) % count )) ;;
        prev) t=$(( (focused_idx - 1 + count) % count )) ;;
    esac
    printf '%s\n' "$ids" | sed -n "$((t + 1))p"
}

action="${1:-toggle}"
case "$action" in
    toggle)
        swaymsg fullscreen toggle >/dev/null
        ;;
    cycle-next|cycle-prev)
        info=$(focused_info)
        [ -n "$info" ] || exit 0
        focused_id=${info% *}
        fs_mode=${info#* }
        direction=${action#cycle-}

        target=$(target_id "$direction" "$focused_id") || exit 0
        if [ "$fs_mode" = "0" ]; then
            # Not in monocle — just cycle focus. Caller will usually
            # pair this with `|| sway-focus-cycle next` in keybinds,
            # but cycling as a fallback is still the right thing.
            swaymsg "[con_id=$target] focus" >/dev/null
        else
            # Monocle active: atomic fullscreen swap in one IPC call.
            swaymsg "[con_id=$focused_id] fullscreen disable; [con_id=$target] focus; [con_id=$target] fullscreen enable" >/dev/null
        fi
        ;;
    is-active)
        info=$(focused_info)
        [ -n "$info" ] || exit 1
        fs_mode=${info#* }
        [ "$fs_mode" != "0" ]
        ;;
    *)
        echo "usage: sway-monocle {toggle|cycle-next|cycle-prev|is-active}" >&2
        exit 2
        ;;
esac
