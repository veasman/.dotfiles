#!/usr/bin/env sh
# sway-kill — mod+q replacement that understands monocle mode.
#
# Without this, killing the visible window while monocle is active
# leaves a seemingly-empty workspace: the hidden windows are still
# parked in the __mono_<ws>__ holding workspace, out of sight. This
# script detects monocle-active state BEFORE killing and, after the
# kill succeeds, restores one hidden window back into view.

set -eu

ws=$(swaymsg -t get_workspaces | jq -r '.[] | select(.focused) | .name')
ws_sanitized=$(printf '%s' "$ws" | sed 's/[^A-Za-z0-9]/_/g')
mark="mono_${ws_sanitized}"

focused=$(swaymsg -t get_tree | jq '
    .. | objects
    | select(.focused == true and (.type == "con" or .type == "floating_con"))
    | .id' | head -1)
[ -n "$focused" ] || exit 0

# Pick a hidden-monocle window to restore AFTER the kill. We grab this
# before the kill so the selection survives sway's tree updates.
next_id=$(swaymsg -t get_tree | jq -r --arg m "$mark" '
    [.. | objects | select(.marks? // [] | any(. == $m)) | .id] | .[0] // empty')

swaymsg "[con_id=$focused] kill" >/dev/null

if [ -n "$next_id" ] && [ "$next_id" != "null" ] && [ "$next_id" != "empty" ]; then
    swaymsg "[con_id=$next_id] move container to workspace $ws" >/dev/null
    swaymsg "[con_id=$next_id] unmark $mark"                    >/dev/null
    swaymsg "[con_id=$next_id] focus"                           >/dev/null
fi
