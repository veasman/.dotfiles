# ── Hermes Agent Environment Configuration ──────────────────────────────
# Copy this file to ~/.hermes/.env and fill in your actual API keys.
#
#   cp .env.template ~/.hermes/.env
#   chmod 600 ~/.hermes/.env
#   $EDITOR ~/.hermes/.env
#
# Required: OPENROUTER_API_KEY — all LLM traffic routes through OpenRouter.

# ── Core LLM Provider (OpenRouter) ──────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# ── Web Search ──────────────────────────────────────────────────────────
# Brave Search API: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=YOUR_BRAVE_SEARCH_API_KEY_HERE

# ── Local FreeLLMAPI proxy (Docker on localhost:3001) ───────────────────
# Provides free-tier models via Cloudflare Workers AI.
FREEFLLMAPI_API_KEY=YOUR_FREEFLLMAPI_API_KEY_HERE

# ── Browser ─────────────────────────────────────────────────────────────
AGENT_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120

# ── Terminal / Sandbox ──────────────────────────────────────────────────
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300

# ── Debug (set to true for verbose logging) ─────────────────────────────
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false

# ── Provider API keys (optional — add if you use them directly) ────────
# See the auto-generated .env from `hermes init` for full list.
# NOVITA_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# OLLAMA_API_KEY=
# GLM_API_KEY=
# KIMI_API_KEY=
# MINIMAX_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
