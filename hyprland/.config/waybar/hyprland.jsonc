// waybar ÔÇö ~/.config/waybar/hyprland.jsonc
//
// Hyprland-side bar. Selected explicitly by hyprland.conf via
// `waybar -c <this> -s ~/.config/waybar/hyprland-style.css`. The
// sway-side stays at config.jsonc + style.css.
//
// Glyphs use \u JSON escapes for portability (so the file is plain
// ASCII on disk; waybar's parser turns them into Nerd Font glyphs).
{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,
    "margin-top": 8,
    "margin-bottom": 0,
    "margin-left": 8,
    "margin-right": 8,

    "modules-left":   ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["hyprland/window"],
    "modules-right":  ["custom/claude", "pulseaudio", "memory", "custom/network", "battery", "clock"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        // Numeric labels ÔÇö position alone (dots) wasn't enough to tell
        // workspaces apart at a glance. The per-output ranges (eDP-1
        // 1-9, DVI-I-2 11-19, DVI-I-1 21-29, DP-2 31-39) all collapse
        // to the single visible digit 1-9 via this map. Active/urgent
        // styling is handled in CSS via .active / .urgent so the glyph
        // stays the digit and the pill carries the state.
        "format": "{icon}",
        "format-icons": {
            "1": "1", "11": "1", "21": "1", "31": "1",
            "2": "2", "12": "2", "22": "2", "32": "2",
            "3": "3", "13": "3", "23": "3", "33": "3",
            "4": "4", "14": "4", "24": "4", "34": "4",
            "5": "5", "15": "5", "25": "5", "35": "5",
            "6": "6", "16": "6", "26": "6", "36": "6",
            "7": "7", "17": "7", "27": "7", "37": "7",
            "8": "8", "18": "8", "28": "8", "38": "8",
            "9": "9", "19": "9", "29": "9", "39": "9"
        },
        "on-click": "activate"
    },

    "hyprland/submap": {
        "format": "<span style=\"italic\"> {}</span>"
    },

    "hyprland/window": {
        "max-length": 80,
        "separate-outputs": true
    },

    "clock": {
        // ´ü│ = nf-fa-calendar
        "format": "´ü│  {:%a %d %b  %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        // ´ïø = nf-fa-microchip
        "format": "´ïø  {usage}%",
        "tooltip": false,
        "interval": 2
    },

    "memory": {
        // ¯┐à = nf-md-memory
        "states":         { "warning": 75, "critical": 90 },
        "format": "¯┐à  {}%",
        "tooltip-format": "{used:0.1f} G / {total:0.1f} G",
        "interval": 5
    },

    "custom/claude": {
        "format": "{}",
        "exec": "claude-usage",
        "return-type": "json",
        "interval": 180
    },

    "custom/network": {
        "exec": "waybar-network",
        "return-type": "json"
    },

    "battery": {
        "states":          { "warning": 30, "critical": 15 },
        "format":          "{icon}  {capacity}%",
        // ´çª = bolt, ´çª = plug
        "format-charging": "´âº  {capacity}%",
        "format-plugged":  "´çª  {capacity}%",
        "format-full":     "´ëÇ  {capacity}%",
        // ramp icons for the regular discharging state
        "format-icons":    ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
        "tooltip-format":  "{timeTo} ({power} W)"
    },

    "pulseaudio": {
        "format":           "{icon}  {volume}%",
        "format-muted":     "´Ü®  muted",
        "format-bluetooth": "´èô  {volume}%",
        "format-icons": {
            // low / mid / high speaker glyphs
            "default": ["´Çª", "´Çº", "´Ç¿"]
        },
        "on-click":         "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right":   "hyprctl dispatch togglespecialworkspace media",
        "scroll-step": 5
    }
}
