// waybar вЂ” ~/.config/waybar/hyprland.jsonc
//
// Hyprland-side bar. Selected explicitly by hyprland.conf via
// `waybar -c <this> -s ~/.config/waybar/hyprland-style.css`. The
// sway-side stays at config.jsonc + style.css.
//
// Glyphs use \u JSON escapes for portability (so the file is plain
// ASCII on disk; waybar's parser turns them into Nerd Font glyphs).
{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,
    "margin-top": 8,
    "margin-bottom": 0,
    "margin-left": 8,
    "margin-right": 8,

    "modules-left":   ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["hyprland/window"],
    "modules-right":  ["custom/claude", "custom/audio", "memory", "custom/network", "battery", "clock"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        // Numeric labels вЂ” position alone (dots) wasn't enough to tell
        // workspaces apart at a glance. The per-output ranges (laptop
        // 1-9, left 11-19, center 21-29, right 31-39) all collapse to
        // the visible digit 1-9 via this map. Connector names are NOT
        // referenced here because DisplayLink/evdi renames them across
        // kernel loads вЂ” the ranges are absolute and stable regardless
        // of what the outputs happen to be called.
        // Active/urgent styling is handled in CSS via .active / .urgent
        // so the glyph stays the digit and the pill carries the state.
        "format": "{icon}",
        "format-icons": {
            "1": "1", "11": "1", "21": "1", "31": "1",
            "2": "2", "12": "2", "22": "2", "32": "2",
            "3": "3", "13": "3", "23": "3", "33": "3",
            "4": "4", "14": "4", "24": "4", "34": "4",
            "5": "5", "15": "5", "25": "5", "35": "5",
            "6": "6", "16": "6", "26": "6", "36": "6",
            "7": "7", "17": "7", "27": "7", "37": "7",
            "8": "8", "18": "8", "28": "8", "38": "8",
            "9": "9", "19": "9", "29": "9", "39": "9"
        },
        "on-click": "activate"
    },

    "hyprland/submap": {
        "format": "<span style=\"italic\"> {}</span>"
    },

    "hyprland/window": {
        "max-length": 80,
        "separate-outputs": true
    },

    "clock": {
        // пЃі = nf-fa-calendar
        "format": "пЃі  {:%a %d %b  %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        // п‹› = nf-fa-microchip
        "format": "п‹›  {usage}%",
        "tooltip": false,
        "interval": 2
    },

    "memory": {
        // ої… = nf-md-memory
        "states":         { "warning": 75, "critical": 90 },
        "format": "ої…  {}%",
        "tooltip-format": "{used:0.1f} G / {total:0.1f} G",
        "interval": 5
    },

    "custom/claude": {
        "format": "{}",
        "exec": "hermes-usage",
        "return-type": "json",
        "interval": 30
    },

    "custom/network": {
        "exec": "waybar-network",
        "return-type": "json"
    },

    "battery": {
        "states":          { "warning": 30, "critical": 15 },
        "format":          "{icon}  {capacity}%",
        // п‡¦ = bolt, п‡¦ = plug
        "format-charging": "пѓ§  {capacity}%",
        "format-plugged":  "п‡¦  {capacity}%",
        "format-full":     "п‰Ђ  {capacity}%",
        // ramp icons for the regular discharging state
        "format-icons":    ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
        "tooltip-format":  "{timeTo} ({power} W)"
    },

    "custom/audio": {
        "exec": "hermes-audio",
        "format": "{}",
        "return-type": "json",
        "interval": 2,
        "on-click":         "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right":   "hyprctl dispatch togglespecialworkspace media",
        "on-scroll-up":     "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down":   "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
    }
}
