// waybar вЂ” ~/.config/waybar/hyprland.jsonc
//
// Hyprland-side bar. Selected explicitly by hyprland.conf via
// `waybar -c <this> -s ~/.config/waybar/hyprland-style.css`. The
// sway-side stays at config.jsonc + style.css.
//
// Glyphs use \u JSON escapes for portability (so the file is plain
// ASCII on disk; waybar's parser turns them into Nerd Font glyphs).
{
    "layer": "top",
    "position": "top",
    "height": 40,
    "spacing": 10,
    "margin-top": 10,
    "margin-bottom": 0,
    "margin-left": 16,
    "margin-right": 16,

    "modules-left":   ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["hyprland/window"],
    "modules-right":  ["custom/claude", "pulseaudio", "memory", "cpu", "network", "battery", "clock"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}",
        "on-click": "activate"
    },

    "hyprland/submap": {
        "format": "<span style=\"italic\"> {}</span>"
    },

    "hyprland/window": {
        "max-length": 80,
        "separate-outputs": true
    },

    "clock": {
        // пЃі = nf-fa-calendar
        "format": "пЃі  {:%a %d %b  %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        // п‹› = nf-fa-microchip
        "format": "п‹›  {usage}%",
        "tooltip": false,
        "interval": 2
    },

    "memory": {
        // ої… = nf-md-memory
        "format": "ої…  {}%",
        "tooltip-format": "{used:0.1f} G / {total:0.1f} G",
        "interval": 5
    },

    "custom/claude": {
        "format": "{}",
        "exec": "claude-usage",
        "interval": 30,
        "tooltip": false
    },

    "network": {
        "interface": "wlan0",
        // п‡« = nf-fa-wifi, п›ї = nf-mdi-ethernet, п‰­ = nf-md-network_off
        "format-wifi":         "п‡«  {signalStrength}%",
        "format-ethernet":     "п›ї  {ifname}",
        "format-disconnected": "п‰­  offline",
        "format-linked":       "п›ї  linked",
        "tooltip-format":      "{ifname}: {ipaddr}/{cidr}"
    },

    "battery": {
        "states":          { "warning": 30, "critical": 15 },
        "format":          "{icon}  {capacity}%",
        // п‡¦ = bolt, п‡¦ = plug
        "format-charging": "пѓ§  {capacity}%",
        "format-plugged":  "п‡¦  {capacity}%",
        "format-full":     "п‰Ђ  {capacity}%",
        // ramp icons for the regular discharging state
        "format-icons":    ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
        "tooltip-format":  "{timeTo} ({power} W)"
    },

    "pulseaudio": {
        "format":           "{icon}  {volume}%",
        "format-muted":     "пљ©  muted",
        "format-bluetooth": "пЉ“  {volume}%",
        "format-icons": {
            // low / mid / high speaker glyphs
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click":         "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right":   "hyprctl dispatch togglespecialworkspace media",
        "scroll-step": 5
    }
}
