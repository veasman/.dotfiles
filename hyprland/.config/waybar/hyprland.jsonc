// waybar — ~/.config/waybar/hyprland.jsonc
//
// Hyprland-specific waybar config. Mirrors the sway config (same
// modules + style.css) but swaps the workspace module to
// hyprland/workspaces and uses format-icons to display the per-output
// 1-9 regardless of the absolute workspace ID (eDP-1=1-9,
// DVI-I-2=11-19, DVI-I-1=21-29, DP-2=31-39).
//
// Selected explicitly via start-hyprland: `waybar -c <this file> -s
// ~/.config/waybar/style.css`. Sway continues to use config.jsonc.
{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 4,

    "modules-left":   ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["hyprland/window"],
    "modules-right":  ["memory", "cpu", "custom/claude", "pulseaudio", "network", "battery", "clock"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}"
    },

    "hyprland/submap": {
        "format": "<span style=\"italic\"> {}</span>"
    },

    "hyprland/window": {
        "max-length": 70,
        "separate-outputs": true
    },

    "clock": {
        "format": " {:%a %d %b %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        "format": " {usage}%",
        "tooltip": false,
        "interval": 2
    },

    "memory": {
        "format": " {}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
        "interval": 5
    },

    "custom/claude": {
        "format": "{}",
        "exec": "claude-usage",
        "interval": 30,
        "tooltip": false
    },

    "network": {
        "interface": "wlan0",
        "format-wifi":         "  {signalStrength}%",
        "format-ethernet":     " {ifname}",
        "format-disconnected": " offline",
        "format-linked":       " linked",
        "tooltip-format":      "{ifname}: {ipaddr}/{cidr}"
    },

    "battery": {
        "states":          { "warning": 30, "critical": 15 },
        "format":          "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged":  " {capacity}%",
        "format-full":     " {capacity}%",
        "format-icons":    ["", "", "", "", ""],
        "tooltip-format":  "{timeTo} ({power}W)"
    },

    "pulseaudio": {
        "format":           "{icon} {volume}%",
        "format-muted":     " muted",
        "format-bluetooth": " {volume}%",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click":         "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right":   "hyprland-scratch-show mixer 'kara-toe-client --app-id=pulsemixer pulsemixer'",
        "scroll-step": 5
    }
}
