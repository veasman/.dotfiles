#!/usr/bin/env sh
# hyprland-ws — per-output workspace switcher (port of sway-ws).
#
# Hyprland's workspaces are global by default, but workspace= rules
# in hyprland.conf pin ranges to specific monitors:
#     r[1-9]   → eDP-1
#     r[11-19] → DVI-I-2
#     r[21-29] → DVI-I-1
#     r[31-39] → DP-2
#
# This script translates `mod+N` into the right absolute workspace ID
# for whichever monitor is currently focused, so each output gets its
# own independent 1-9 like kara's per-monitor model.
#
# Usage:
#   hyprland-ws switch <1..9>   focus workspace N on the focused output
#   hyprland-ws move   <1..9>   send focused window to N on focused output

set -eu

cmd="${1:?usage: hyprland-ws {switch|move} <N>}"
n="${2:?usage: hyprland-ws {switch|move} <N>}"

monitor=$(hyprctl monitors -j | jq -r '.[] | select(.focused) | .name')
case "$monitor" in
    eDP-1)   base=0  ;;
    DVI-I-2) base=10 ;;
    DVI-I-1) base=20 ;;
    DP-2)    base=30 ;;
    *)       base=40 ;;
esac

ws=$((base + n))

case "$cmd" in
    switch) hyprctl dispatch workspace "$ws" >/dev/null ;;
    move)   hyprctl dispatch movetoworkspace "$ws" >/dev/null ;;
    *)
        echo "usage: hyprland-ws {switch|move} <N>" >&2
        exit 1
        ;;
esac
