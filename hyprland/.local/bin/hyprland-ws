#!/usr/bin/env sh
# hyprland-ws — per-output workspace switcher.
#
# Computes the base offset (0, 10, 20, 30) dynamically from monitor
# positions, so connector-name flapping (DisplayLink/evdi) doesn't
# break the mapping.  Waybar's format-icons map in hyprland.jsonc
# already collapses the tens-digit so the bar shows 1-9 on every
# monitor regardless of the absolute workspace ID.
#
# Usage:
#   hyprland-ws switch <1..9>   focus workspace N on focused output
#   hyprland-ws move   <1..9>   send focused window to N on focused output
#   hyprland-ws center           print name of the center (1440p) monitor

set -eu

usage='usage: hyprland-ws (switch|move) <N> | center'
cmd="${1:?$usage}"

# All monitors sorted by X position (left → right).
sorted=$(hyprctl monitors -j | jq -r 'sort_by(.x) | .[] | .name')

if [ "$cmd" = "center" ]; then
    # Find the 1440p monitor (LG center).  Fall back to the first
    # external (skip eDP-1) or just eDP-1.
    center=$(hyprctl monitors -j | jq -r '.[] | select(.width == 2560) | .name' 2>/dev/null | head -1)
    if [ -n "$center" ]; then
        printf '%s' "$center"
    else
        printf '%s' "$sorted" | sed -n '1p'
    fi
    exit 0
fi

n="${2:?usage}"

monitor=$(hyprctl monitors -j | jq -r '.[] | select(.focused) | .name')

# Base offset by monitor position among EXTERNAL monitors only.
# eDP-1 (laptop) always gets base 0 regardless of its position.
if [ "$monitor" = "eDP-1" ]; then
    base=0
else
    # 1-based index among non-eDP-1 monitors sorted by X:
    #   first  external → base 10
    #   second external → base 20
    #   third  external → base 30
    index=$(printf '%s\n' "$sorted" | grep -v '^eDP-1$' | grep -nFx "$monitor" | cut -d: -f1)
    base=$((index * 10))
fi

ws=$((base + n))

case "$cmd" in
    switch) hyprctl dispatch workspace "$ws" >/dev/null ;;
    move)   hyprctl dispatch movetoworkspace "$ws" >/dev/null ;;
    *)
        echo "usage: hyprland-ws {switch|move} <N>" >&2
        exit 1
        ;;
esac
