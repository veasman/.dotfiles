#!/usr/bin/env sh
# hyprland-scratch-show — spawn-on-demand + toggle a special workspace.
#
# On first press the script uses `hyprctl dispatch exec
# '[workspace special:NAME silent] CMD'` so the windowrule is applied
# at spawn time, BEFORE the window maps. This avoids the race we saw
# with `windowrulev2 = workspace special:NAME silent, class:...`,
# where the window briefly appeared in the active workspace before
# the rule moved it (then ended up looking like it spawned "as the
# scratchpad was closing").
#
# Subsequent presses just toggle the special workspace.
#
# Usage:
#   hyprland-scratch-show <special-name> <spawn-command...>

set -eu

ws_name="${1:?special workspace name required}"
shift
spawn="$*"
[ -n "$spawn" ] || { echo "spawn command required" >&2; exit 1; }

count_in_special() {
    hyprctl clients -j | jq --arg ws "special:$ws_name" \
        '[.[] | select(.workspace.name == $ws)] | length'
}

if [ "$(count_in_special)" = "0" ]; then
    # Use Hyprland's exec-with-rules form so the workspace assignment
    # is applied at spawn rather than relying on a windowrulev2 match.
    hyprctl dispatch exec "[workspace special:$ws_name silent] $spawn" >/dev/null

    # Wait up to ~2s for the window to actually map into the special.
    tries=20
    while [ "$tries" -gt 0 ]; do
        [ "$(count_in_special)" != "0" ] && break
        sleep 0.1
        tries=$((tries - 1))
    done
fi

hyprctl dispatch togglespecialworkspace "$ws_name" >/dev/null
