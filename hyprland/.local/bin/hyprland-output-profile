#!/usr/bin/env sh
# hyprland-output-profile — dynamic docked/undocked monitor layout.
#
# Identifies monitors by resolution, then uses a cached connector→side
# mapping (keyed by serial number) so that DisplayLink/evdi connector
# renames don't break the layout.
#
# Layout:
#   Docked (1440p present):
#     left   1920x1080 → portrait-left   @ 0       (transform 1)
#     center 2560x1440 → center           @ 1080   (landscape)
#     right  1920x1080 → portrait-right  @ 3640   (transform 3)
#     eDP-1            → disabled
#
#   Undocked (no 1440p):
#     eDP-1 → enabled at preferred / auto
#
# Also binds workspace ranges (r[11-19] left, r[21-29] center,
# r[31-39] right) so per-output IDs stay correct.
#
# Usage:
#   hyprland-output-profile           # apply layout (daemon mode)
#   hyprland-output-profile --swap    # swap cached left↔right sides
#   hyprland-output-profile --redetect  # clear cache and re-detect

set -eu

# --- state file (persists connector→side mapping across renames) -----
STATE_DIR="$HOME/.local/state/hypr"
STATE="$STATE_DIR/output-layout"
mkdir -p "$STATE_DIR" 2>/dev/null || true

read_state()  { [ -f "$STATE" ] && . "$STATE" || true; }
write_state() {
    printf 'left=%s\ncenter=%s\nright=%s\n' \
        "$left" "$center" "$right" > "$STATE"
}

# --- logging ---------------------------------------------------------
SETTLE="${HYPR_OUTPUT_PROFILE_SETTLE:-1.2}"
LOGFILE="$HOME/.cache/hypr/output-profile.log"
mkdir -p "$(dirname "$LOGFILE")" 2>/dev/null || true
log() {
    printf '%s %s\n' \
        "$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo '?')" "$*" \
        >>"$LOGFILE" 2>/dev/null || true
}

# --- core -------------------------------------------------------------
apply_profile() {
    all=$(hyprctl monitors -j 2>/dev/null | jq -c '.[]' || true)
    names_connected=$(printf '%s\n' "$all" | jq -r '.name' | tr '\n' ' ')
    log "apply: connected = $names_connected"

    laptop="eDP-1"
    center=$(printf '%s\n' "$all" | jq -r 'select(.width == 2560) | .name' | head -1)

    if [ -n "$center" ]; then
        # ------ docked ------
        read_state
        names_list=$(printf '%s\n' "$all" | jq -r '.name')
        stale=false
        for v in "${left:-}" "${center:-}" "${right:-}"; do
            [ -n "$v" ] || { stale=true; break; }
            printf '%s\n' "$names_list" | grep -Fxq "$v" || { stale=true; break; }
        done
        center_name=$(printf '%s\n' "$all" | jq -r 'select(.width == 2560) | .name' | head -1)
        if $stale; then
            log "state stale — re-detecting"
            pairs=$(printf '%s\n' "$all" \
                | jq -r 'select(.width == 1920 and .height == 1080) | "\(.x) \(.name)"')
            distinct_x=$(printf '%s\n' "$pairs" | awk '{print $1}' | sort -u | wc -l)
            if [ "$distinct_x" -ge 2 ]; then
                left=$(printf '%s\n' "$pairs" | sort -n -k1 | awk '{print $2}' | sed -n '1p')
                right=$(printf '%s\n' "$pairs" | sort -n -k1 | awk '{print $2}' | sed -n '2p')
            else
                names=$(printf '%s\n' "$all" \
                    | jq -r 'select(.width == 1920 and .height == 1080) | .name' | sort)
                left=$(printf '%s\n' "$names" | sed -n '1p')
                right=$(printf '%s\n' "$names" | sed -n '2p')
                log "  fallback heuristic: left=$left right=$right"
            fi
            center="$center_name"
            write_state
        fi

        log "apply: docked  left=$left  center=$center  right=$right"

        [ -n "$left"  ] && hyprctl keyword monitor "$left,1920x1080,0x0,1,transform,1"    >/dev/null 2>&1 || true
                               hyprctl keyword monitor "$center,2560x1440@120,1080x0,1"    >/dev/null 2>&1 || true
        [ -n "$right" ] && hyprctl keyword monitor "$right,1920x1080,3640x0,1,transform,3" >/dev/null 2>&1 || true
                               hyprctl keyword monitor "$laptop,disable"                   >/dev/null 2>&1 || true

        [ -n "$left"  ] && hyprctl keyword workspace "r[11-19],monitor:$left,default:true"   >/dev/null 2>&1 || true
                               hyprctl keyword workspace "r[21-29],monitor:$center,default:true" >/dev/null 2>&1 || true
        [ -n "$right" ] && hyprctl keyword workspace "r[31-39],monitor:$right,default:true"  >/dev/null 2>&1 || true

        hyprctl dispatch focusmonitor "$center"                           >/dev/null 2>&1 || true"
    else
        # ------ undocked ------
        log "apply: undocked -> enabling $laptop"
        hyprctl keyword monitor "$laptop,preferred,auto,1"                >/dev/null 2>&1 || true
        hyprctl dispatch focusmonitor "$laptop"                           >/dev/null 2>&1 || true
    fi
}

# --- side-swap helper -------------------------------------------------
swap_sides() {
    read_state
    if [ -z "${left:-}" ] || [ -z "${right:-}" ]; then
        echo "no cached layout to swap — run the daemon first" >&2
        exit 1
    fi
    tmp="$left"; left="$right"; right="$tmp"
    write_state
    echo "swapped: left=$left right=$right"
    apply_profile
}

# --- CLI (runs BEFORE the daemon lock so --swap isn't blocked) --------
case "${1:-}" in
    --swap|--swap-sides)
        swap_sides
        exit 0
        ;;
    --redetect)
        rm -f "$STATE"
        apply_profile
        exit 0
        ;;
esac

# --- daemon lock ------------------------------------------------------
RUNTIME="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
LOCK="$RUNTIME/hyprland-output-profile.lock"
exec 9>"$LOCK"
flock -n 9 || exit 0

# --- debounced apply (collapses connector-flap storms) -----------------
pending_pid=""
schedule_apply() {
    if [ -n "$pending_pid" ]; then
        kill "$pending_pid" 2>/dev/null || true
        wait "$pending_pid" 2>/dev/null || true
    fi
    { sleep "$SETTLE"; apply_profile; } &
    pending_pid=$!
}

# --- daemon entry point -----------------------------------------------
log "start (settle=${SETTLE}s)"
apply_profile

SOCK="$RUNTIME/hypr/${HYPRLAND_INSTANCE_SIGNATURE:-}/.socket2.sock"
[ -S "$SOCK" ] || { log "no socket2 at $SOCK; exiting"; exit 0; }

if command -v socat >/dev/null 2>&1; then
    socat -U - "UNIX-CONNECT:$SOCK" 2>/dev/null | while IFS= read -r line; do
        case "$line" in
            monitoradded*|monitorremoved*|monitoraddedv2*|monitorremovedv2*)
                log "event: ${line%%>>*}"
                schedule_apply
                ;;
        esac
    done
fi
