#!/usr/bin/env sh
# hyprland-hyprpaper — start hyprpaper with a home-relative fallback path.
# hyprpaper does not expand $HOME or ~ in config files, so we write the
# absolute path at runtime to stay portable across usernames.
set -eu

CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/hypr"
CONF="$CONF_DIR/hyprpaper-generated.conf"

mkdir -p "$CONF_DIR"

cat > "$CONF" << CONFEOF
# Auto-generated by hyprland-hyprpaper — do not edit.
# Actual wallpaper changes go through hyprland-wallpaper apply (IPC).
preload = $HOME/.local/state/sway/wallpapers/default.png
wallpaper = , $HOME/.local/state/sway/wallpapers/default.png
ipc = on
splash = false
CONFEOF

exec hyprpaper -c "$CONF"
