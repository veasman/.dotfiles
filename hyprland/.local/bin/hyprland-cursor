#!/usr/bin/env sh
# hyprland-cursor — preview-cycle cursor theme picker.
#
# Same UX as hyprland-wallpaper, but for cursor themes via
# `hyprctl setcursor THEME SIZE`. Selection is persisted to
# ~/.local/state/hypr/cursor-current and re-applied at session start
# via the `apply` action (run from hyprland.conf exec-once).
#
# Themes are scanned from /usr/share/icons, ~/.local/share/icons,
# and ~/.icons. A theme directory must contain a cursors/ subdir
# to count as a cursor theme.
#
# Defaults:
#   HYPR_CURSOR_SIZE     (default 20)
#   HYPR_CURSOR_DEFAULT  (default Bibata-Modern-Classic)
#
# Actions:
#   apply    apply the committed theme (no cycling)
#   next     cycle preview to the next theme
#   prev     cycle preview to the previous theme
#   commit   make the current preview the committed selection
#   revert   discard the preview, re-apply the committed selection

set -eu

STATE_DIR="$HOME/.local/state/hypr"
CURRENT_FILE="$STATE_DIR/cursor-current"
PREVIEW_FILE="$STATE_DIR/cursor-preview"
SIZE="${HYPR_CURSOR_SIZE:-20}"
DEFAULT_THEME="${HYPR_CURSOR_DEFAULT:-Bibata-Modern-Classic}"

mkdir -p "$STATE_DIR"

list_themes() {
    for dir in /usr/share/icons "$HOME/.local/share/icons" "$HOME/.icons"; do
        [ -d "$dir" ] || continue
        for theme in "$dir"/*; do
            [ -d "$theme/cursors" ] || continue
            basename "$theme"
        done
    done | sort -u
}

current_theme() {
    if [ -s "$CURRENT_FILE" ]; then
        cat "$CURRENT_FILE"
    else
        echo "$DEFAULT_THEME"
    fi
}

apply() {
    theme="$1"
    [ -n "$theme" ] || return 1
    hyprctl setcursor "$theme" "$SIZE" >/dev/null 2>&1 || true
}

cycle() {
    direction="$1"
    list=$(list_themes)
    count=$(printf '%s\n' "$list" | grep -c .)
    [ "$count" -gt 1 ] || return 0

    if [ -s "$PREVIEW_FILE" ]; then
        cur=$(cat "$PREVIEW_FILE")
    else
        cur=$(current_theme)
    fi

    idx=$(printf '%s\n' "$list" | awk -v t="$cur" '$0 == t { print NR; exit }')
    [ -n "$idx" ] || idx=1
    case "$direction" in
        next) target_idx=$(( idx % count + 1 )) ;;
        prev) target_idx=$(( (idx - 2 + count) % count + 1 )) ;;
    esac
    target=$(printf '%s\n' "$list" | sed -n "${target_idx}p")
    [ -n "$target" ] || return 1

    apply "$target"
    printf '%s' "$target" > "$PREVIEW_FILE"
}

action="${1:-apply}"
case "$action" in
    apply)
        apply "$(current_theme)"
        ;;
    next|prev)
        cycle "$action"
        ;;
    commit)
        if [ -s "$PREVIEW_FILE" ]; then
            cp "$PREVIEW_FILE" "$CURRENT_FILE"
            rm -f "$PREVIEW_FILE"
        fi
        ;;
    revert)
        rm -f "$PREVIEW_FILE"
        apply "$(current_theme)"
        ;;
    *)
        echo "usage: hyprland-cursor {apply|next|prev|commit|revert}" >&2
        exit 1
        ;;
esac
