#!/usr/bin/env sh
# hyprland-terminal — detect available terminal emulator
# Prefers footclient/foot (fast, lightweight); falls back to kara-toe-client.
set -eu

if command -v footclient >/dev/null 2>&1; then
    exec footclient "$@"
fi

if command -v foot >/dev/null 2>&1; then
    exec foot "$@"
fi

if command -v kara-toe-client >/dev/null 2>&1; then
    exec kara-toe-client "$@"
fi

echo "hyprland-terminal: no terminal emulator found (tried footclient, foot, kara-toe-client)" >&2
exit 1
