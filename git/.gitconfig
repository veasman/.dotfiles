[include]
    path = ~/.gitconfig.user

[core]
    editor = nvim
    pager = less -FRX

[init]
    defaultBranch = master

[pull]
    rebase = false

[push]
    autoSetupRemote = true

[color]
    ui = auto

[alias]
    st = status
    co = checkout
    br = branch
    lg = log --oneline --graph --decorate
    amend = commit --amend --no-edit
