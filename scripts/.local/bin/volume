#!/usr/bin/env sh
# volume — adjust output sink + render a HUD.
#
# Path A (preferred): when swayosd-server is running, delegate the
# whole thing to swayosd-client — small centered OSD, native pill,
# no full-width notification card. swayosd handles the wpctl/pactl
# query and the bar rendering itself.
#
# Path B (fallback): emit a swaync progress notification with the
# dim-dot pango pattern. Used when no swayosd-server is up — i.e.
# in sway/kara sessions or before swayosd autostarts.
#
# Usage: volume {up|down|mute}

set -eu

if pgrep -x swayosd-server >/dev/null 2>&1; then
    case "${1:-}" in
        up)   exec swayosd-client --output-volume raise ;;
        down) exec swayosd-client --output-volume lower ;;
        mute) exec swayosd-client --output-volume mute-toggle ;;
        *)    echo "usage: $(basename "$0") {up|down|mute}" >&2; exit 1 ;;
    esac
fi

SINK="@DEFAULT_AUDIO_SINK@"
STEP=5

# Pango markup colors — dim grey for separator + value.
DIM='#5c5c5c'
VAL='#a8a8a8'

case "${1:-}" in
    up)   wpctl set-volume -l 1.5 "$SINK" "${STEP}%+" ;;
    down) wpctl set-volume "$SINK" "${STEP}%-" ;;
    mute) wpctl set-mute "$SINK" toggle ;;
    *)    echo "usage: $(basename "$0") {up|down|mute}" >&2; exit 1 ;;
esac

state=$(wpctl get-volume "$SINK")
muted=0
case "$state" in *MUTED*) muted=1 ;; esac
volume=$(printf '%s' "$state" | awk '{print $2}')
pct=$(awk -v v="$volume" 'BEGIN { printf "%d", v * 100 + 0.5 }')

if [ "$muted" = "1" ]; then
    icon="audio-volume-muted"
    body="Volume <span foreground=\"$DIM\">·</span> <span foreground=\"$VAL\">muted</span>"
    value=0
else
    if   [ "$pct" -ge 67 ]; then icon="audio-volume-high"
    elif [ "$pct" -ge 34 ]; then icon="audio-volume-medium"
    elif [ "$pct" -gt 0 ];  then icon="audio-volume-low"
    else                         icon="audio-volume-muted"
    fi
    body="Volume <span foreground=\"$DIM\">·</span> <span foreground=\"$VAL\">${pct}%</span>"
    value=$pct
fi

notify-send -t 1500 \
    -h "string:x-canonical-private-synchronous:volume" \
    -h "int:value:$value" \
    -i "$icon" \
    "" "$body"
