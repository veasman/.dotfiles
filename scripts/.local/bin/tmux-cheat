#!/usr/bin/env bash
set -euo pipefail

CHEAT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/cheat"
LANG_FILE="$CHEAT_DIR/languages"
CMD_FILE="$CHEAT_DIR/commands"

selected="$(cat "$LANG_FILE" "$CMD_FILE" | fzf || true)"
[[ -n "${selected:-}" ]] || exit 0

read -r -p "Enter Query: " query

if grep -qsx "$selected" "$LANG_FILE"; then
  query="$(echo "$query" | tr ' ' '+')"
  tmux new-window -n "cheat:$selected" "bash -lc 'echo \"curl cht.sh/$selected/$query/\"; curl cht.sh/$selected/$query; exec bash'"
else
  tmux new-window -n "cheat:$selected" "bash -lc 'curl -s cht.sh/$selected~$query | less'"
fi
