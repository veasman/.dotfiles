#!/usr/bin/env sh
# hyprland-pywal — extract a palette from a wallpaper and propagate it
# to waybar + Hyprland live, optionally in lockstep with the wallpaper
# preview cycle.
#
# Subcommands:
#   apply <path>   regenerate the palette from <path> and push it
#   enable         turn pywal mode on (flag file)
#   disable        turn pywal mode off and restore the kara defaults
#   toggle         flip the flag, applying/restoring as needed
#   is-enabled     exit 0 if enabled, 1 otherwise
#   init           ensure the waybar colors file exists (kara defaults)
#
# Mechanics:
#  * `wal` extracts the 16-color palette → ~/.cache/wal/colors.json.
#  * We rewrite ~/.config/waybar/hyprland-colors.css with @define-color
#    overrides for accent / accent_dim / warn / err. The main waybar CSS
#    @imports this file, so a SIGUSR2 reload picks the new palette up.
#  * Hyprland border colors are pushed live via `hyprctl keyword`, so
#    no full reload is needed — colors swap in step with the preview.
#
# Pywal palette index choices:
#   color12 → bright accent (active workspace, clock tint, focused border)
#   color4  → muted accent (gradient bottoms, inactive border secondary)
#   color11 → warn fallback (yellow-ish in most palettes)
#   color9  → err fallback (red-ish in most palettes)

set -eu

STATE_DIR="$HOME/.local/state/hypr"
FLAG_FILE="$STATE_DIR/pywal-enabled"
WAYBAR_COLORS="$HOME/.config/waybar/hyprland-colors.css"
HYPRLOCK_COLORS="$HOME/.cache/wal/hyprlock-colors.conf"
WALLPAPER_CURRENT="$STATE_DIR/wallpaper-current"
WALLPAPER_PREVIEW="$STATE_DIR/wallpaper-preview"

mkdir -p "$STATE_DIR" "$(dirname "$WAYBAR_COLORS")" "$(dirname "$HYPRLOCK_COLORS")"

# Kara palette defaults — used when pywal is off or as bootstrap.
KARA_ACCENT="#8fd3d3"
KARA_ACCENT_DIM="#6bacac"
KARA_WARN="#ebcb8b"
KARA_ERR="#bf616a"

write_waybar_colors() {
    accent=$1; accent_dim=$2; warn=$3; err=$4
    tmp="${WAYBAR_COLORS}.tmp"
    {
        echo "/* Generated by hyprland-pywal — do not hand-edit. */"
        echo "@define-color accent     ${accent};"
        echo "@define-color accent_dim ${accent_dim};"
        echo "@define-color warn       ${warn};"
        echo "@define-color err        ${err};"
    } > "$tmp"
    mv "$tmp" "$WAYBAR_COLORS"
}

write_hyprlock_colors() {
    accent=$1; accent_dim=$2
    a_hex="${accent#\#}"
    d_hex="${accent_dim#\#}"
    tmp="${HYPRLOCK_COLORS}.tmp"
    {
        echo "# Generated by hyprland-pywal — do not hand-edit."
        echo "# rgba alpha values let the lockscreen blend the accent"
        echo "# into the blurred background instead of pasting it on."
        echo "\$accent      = rgba(${a_hex}ee)"
        echo "\$accent_soft = rgba(${a_hex}aa)"
        echo "\$accent_text = rgba(${a_hex}ff)"
        echo "\$accent_dim  = rgba(${d_hex}cc)"
    } > "$tmp"
    mv "$tmp" "$HYPRLOCK_COLORS"
}

push_hyprland_colors() {
    accent=$1; accent_dim=$2
    a_hex="${accent#\#}"
    d_hex="${accent_dim#\#}"
    # Active border gradient.
    hyprctl keyword general:col.active_border \
        "rgb(${a_hex}) rgb(${d_hex}) rgb(${a_hex}) 45deg" >/dev/null 2>&1 || true
    # Active-window shadow glow at alpha 0x55 (~33%) — soft accent halo
    # that reads as light, not a tinted shadow. Inactive shadow stays
    # neutral (set in hyprland.conf) so only the focus picks up color.
    hyprctl keyword decoration:shadow:color \
        "rgba(${a_hex}55)" >/dev/null 2>&1 || true
}

reload_waybar() {
    pkill -SIGUSR2 waybar 2>/dev/null || true
}

apply_path() {
    path=$1
    [ -f "$path" ] || { echo "hyprland-pywal: not a file: $path" >&2; return 1; }

    if ! command -v wal >/dev/null 2>&1; then
        echo "hyprland-pywal: 'wal' missing — sudo pacman -S python-pywal" >&2
        return 1
    fi
    if ! command -v jq >/dev/null 2>&1; then
        echo "hyprland-pywal: 'jq' missing" >&2
        return 1
    fi

    wal -i "$path" -n -s -t -q >/dev/null 2>&1 || {
        echo "hyprland-pywal: wal failed for $path" >&2
        return 1
    }

    j="$HOME/.cache/wal/colors.json"
    [ -f "$j" ] || { echo "hyprland-pywal: no colors.json after wal run" >&2; return 1; }

    accent=$(jq -r '.colors.color12' "$j")
    accent_dim=$(jq -r '.colors.color4' "$j")
    warn=$(jq -r '.colors.color11' "$j")
    err=$(jq -r '.colors.color9' "$j")

    write_waybar_colors "$accent" "$accent_dim" "$warn" "$err"
    write_hyprlock_colors "$accent" "$accent_dim"
    push_hyprland_colors "$accent" "$accent_dim"
    reload_waybar
}

restore_defaults() {
    write_waybar_colors "$KARA_ACCENT" "$KARA_ACCENT_DIM" "$KARA_WARN" "$KARA_ERR"
    write_hyprlock_colors "$KARA_ACCENT" "$KARA_ACCENT_DIM"
    push_hyprland_colors "$KARA_ACCENT" "$KARA_ACCENT_DIM"
    reload_waybar
}

current_wallpaper() {
    if [ -s "$WALLPAPER_PREVIEW" ]; then
        cat "$WALLPAPER_PREVIEW"
    elif [ -s "$WALLPAPER_CURRENT" ]; then
        cat "$WALLPAPER_CURRENT"
    fi
}

action="${1:-}"
case "$action" in
    apply)
        path="${2:?usage: hyprland-pywal apply <path>}"
        apply_path "$path"
        ;;
    enable)
        : > "$FLAG_FILE"
        if ! command -v wal >/dev/null 2>&1; then
            # Surface the missing dep loudly instead of leaving the user
            # wondering why colors won't shift. Notification first, then
            # stderr for shell invocations.
            notify-send -u normal -t 6000 'pywal not installed' \
                'Run: sudo pacman -S python-pywal' 2>/dev/null || true
            echo "hyprland-pywal: 'wal' missing — sudo pacman -S python-pywal" >&2
            exit 0
        fi
        cur=$(current_wallpaper)
        [ -n "$cur" ] && apply_path "$cur"
        ;;
    disable)
        rm -f "$FLAG_FILE"
        restore_defaults
        ;;
    toggle)
        if [ -f "$FLAG_FILE" ]; then
            "$0" disable
        else
            "$0" enable
        fi
        ;;
    is-enabled)
        [ -f "$FLAG_FILE" ]
        ;;
    init)
        [ -f "$WAYBAR_COLORS" ] || write_waybar_colors \
            "$KARA_ACCENT" "$KARA_ACCENT_DIM" "$KARA_WARN" "$KARA_ERR"
        [ -f "$HYPRLOCK_COLORS" ] || write_hyprlock_colors \
            "$KARA_ACCENT" "$KARA_ACCENT_DIM"
        ;;
    *)
        echo "usage: hyprland-pywal {apply <path>|enable|disable|toggle|is-enabled|init}" >&2
        exit 1
        ;;
esac
