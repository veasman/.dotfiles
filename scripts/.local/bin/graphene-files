#!/bin/bash
# Quick mount/unmount script for GrapheneOS phone via MTP
# Usage:
#   graphene-files            - mount (default)
#   graphene-files mount      - mount
#   graphene-files unmount    - unmount
#   graphene-files umount     - unmount
#   graphene-files status     - show mount status

MOUNT_POINT="$HOME/graphene-files"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

ensure_mount_point() {
    if [ ! -d "$MOUNT_POINT" ]; then
        mkdir -p "$MOUNT_POINT"
        echo -e "${YELLOW}Created mount point at $MOUNT_POINT${NC}"
    fi
}

is_mounted() {
    mountpoint -q "$MOUNT_POINT"
}

mount_phone() {
    ensure_mount_point

    if is_mounted; then
        echo -e "${YELLOW}Phone is already mounted at $MOUNT_POINT${NC}"
        return 0
    fi

    echo "Mounting phone..."
    if jmtpfs "$MOUNT_POINT" 2>/dev/null; then
        echo -e "${GREEN}✓ Phone mounted at $MOUNT_POINT${NC}"
        echo "  Browse with: cd $MOUNT_POINT"
        echo "  Unmount with: graphene-files unmount"
    else
        echo -e "${RED}✗ Mount failed${NC}"
        echo "  Check that:"
        echo "  - Phone is plugged in"
        echo "  - USB mode is set to 'File Transfer' on the phone"
        echo "  - Phone screen is unlocked"
        return 1
    fi
}

unmount_phone() {
    if ! is_mounted; then
        echo -e "${YELLOW}Phone is not currently mounted${NC}"
        return 0
    fi

    # Warn if shell is currently inside the mount point
    if [[ "$PWD" == "$MOUNT_POINT"* ]]; then
        echo -e "${YELLOW}Note: your shell is inside the mount point. cd out before unmounting.${NC}"
    fi

    echo "Unmounting phone..."
    if fusermount -u "$MOUNT_POINT" 2>/dev/null; then
        echo -e "${GREEN}✓ Phone unmounted${NC}"
    else
        echo -e "${RED}✗ Unmount failed${NC}"
        echo "  Something may still be using the mount."
        echo "  Try: lsof +D $MOUNT_POINT"
        echo "  Or force unmount: fusermount -uz $MOUNT_POINT"
        return 1
    fi
}

show_status() {
    if is_mounted; then
        echo -e "${GREEN}● Phone is mounted at $MOUNT_POINT${NC}"
        df -h "$MOUNT_POINT" 2>/dev/null | tail -n 1
    else
        echo -e "${YELLOW}○ Phone is not mounted${NC}"
    fi
}

case "${1:-mount}" in
    mount|m|"")
        mount_phone
        ;;
    unmount|umount|u)
        unmount_phone
        ;;
    status|s)
        show_status
        ;;
    *)
        echo "Usage: graphene-files [mount|unmount|status]"
        echo ""
        echo "  mount    - mount phone to $MOUNT_POINT (default)"
        echo "  unmount  - unmount phone"
        echo "  status   - show whether phone is mounted"
        exit 1
        ;;
esac
