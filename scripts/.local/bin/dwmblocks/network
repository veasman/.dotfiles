#!/bin/sh

# get active interface used for default route
iface=$(ip route | awk '/default/ {print $5; exit}')

if [ -z "$iface" ]; then
    echo "OFFLINE"
    exit
fi

ipaddr=$(ip -4 addr show "$iface" | awk '/inet / {print $2}' | cut -d/ -f1)

if echo "$iface" | grep -q "wl"; then
    ssid=$(iw dev "$iface" link | awk -F': ' '/SSID/ {print $2}')
    echo "$ssid $ipaddr"
else
    echo "$iface $ipaddr"
fi
