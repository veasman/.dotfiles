#!/usr/bin/env bash
set -euo pipefail

# pmux-make — launch make targets as tmux windows
#
# Usage:
#   pmux-make                  # read .pmux/layout
#   pmux-make dev logs test    # inline targets
#
# Each argument (or layout line) is passed to make.
# The first word becomes the window name.

PMUX_LOOM_FZF_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/loom/generated/fzf-theme.sh"
PMUX_FZF_BASE_OPTS="${PMUX_FZF_BASE_OPTS:-}"

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "Error: required command not found: $1" >&2
        exit 1
    }
}

require_cmd tmux

session="$(tmux display-message -p "#{session_name}")"
pane_path="$(tmux display-message -p "#{pane_current_path}")"

load_fzf_theme() {
    LOOM_FZF_COLOR_OPTS=""
    if [[ -f "${PMUX_LOOM_FZF_FILE}" ]]; then
        # shellcheck source=/dev/null
        source "${PMUX_LOOM_FZF_FILE}"
    fi
}

current_fzf_opts() {
    load_fzf_theme
    printf '%s' "${PMUX_FZF_BASE_OPTS:+$PMUX_FZF_BASE_OPTS }${LOOM_FZF_COLOR_OPTS:-}"
}

detect_targets() {
    local makefile="$pane_path/Makefile"
    [[ -f "$makefile" ]] || return 0

    awk -F: '
        /^[a-zA-Z0-9_.-]+:/ && $1 !~ /^(\.|%)/ {
            t=$1
            if (t != "PHONY") print t
        }
    ' "$makefile" | sort -u
}

read_layout() {
    local file="$pane_path/.pmux/layout"
    [[ -f "$file" ]] || return 0
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="$(printf '%s' "$line" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
        [[ -z "$line" || "$line" == \#* ]] && continue
        echo "$line"
    done < "$file"
}

pick_targets() {
    local targets
    targets="$(detect_targets)"
    [[ -n "$targets" ]] || { echo "No Makefile found in $pane_path" >&2; exit 1; }

    require_cmd fzf

    local fzf_opts
    fzf_opts="$(current_fzf_opts)"

    printf '%s\n' "$targets" \
        | env -u FZF_DEFAULT_OPTS FZF_DEFAULT_OPTS="$fzf_opts" fzf -m --prompt="make> "
}

run_target() {
    local line="$1"
    local name="${line%% *}"

    local wid
    wid="$(tmux new-window -t "$session:" -n "$name" -c "$pane_path" -P -F "#{window_id}")"
    tmux send-keys -t "$wid" "cd \"$pane_path\" && make $line" C-m
}

main() {
    local entries=()

    if [[ $# -gt 0 ]]; then
        for arg in "$@"; do
            entries+=("$arg")
        done
    elif [[ -f "$pane_path/.pmux/layout" ]]; then
        while IFS= read -r e; do
            [[ -n "$e" ]] && entries+=("$e")
        done < <(read_layout)
    else
        while IFS= read -r e; do
            [[ -n "$e" ]] && entries+=("$e")
        done < <(pick_targets || true)
    fi

    [[ "${#entries[@]}" -gt 0 ]] || exit 0

    for entry in "${entries[@]}"; do
        run_target "$entry"
    done

    local first_name="${entries[0]%% *}"
    tmux select-window -t "$session:$first_name" 2>/dev/null || true
}

main "$@"
