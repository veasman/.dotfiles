#!/usr/bin/env sh
# screenshot — hyprshot/grim wrapper that fires a clickable swaync
# notification with a small square thumbnail of the saved image.
#
# Default-click on the notification opens the file in the system
# image viewer (xdg-open → mimeapps.list → image/png).
#
# All three modes save to ~/Pictures. Region also goes to the
# clipboard so you can paste it directly into chat / docs.
#
# Usage:
#   screenshot output    full focused output → ~/Pictures
#   screenshot window    focused window     → ~/Pictures
#   screenshot region    drag selection     → ~/Pictures + clipboard

set -eu

mode="${1:-output}"
DIR="$HOME/Pictures"
mkdir -p "$DIR"

DIM='#5c5c5c'
VAL='#a8a8a8'

case "$mode" in
    region)
        # Save to a timestamped file, also pipe to wl-copy for paste.
        path="$DIR/screenshot-$(date +%Y%m%d-%H%M%S).png"
        geom=$(slurp -d) || exit 0
        grim -g "$geom" "$path"
        wl-copy -t image/png < "$path"
        ;;
    output|window|active)
        out=$(hyprshot --silent -m "$mode" -o "$DIR" 2>&1 || true)
        path=$(printf '%s' "$out" | grep -oE '/[^[:space:]]+\.png' | head -1)
        if [ -z "$path" ] || [ ! -f "$path" ]; then
            path=$(ls -t "$DIR"/*.png 2>/dev/null | head -1)
        fi
        ;;
    *)
        echo "usage: $(basename "$0") {output|window|region}" >&2
        exit 1
        ;;
esac

[ -f "$path" ] || { echo "screenshot failed: no file produced" >&2; exit 1; }
filename=$(basename "$path")

# image-path hint puts the screenshot in swaync's body image slot
# (square thumbnail, sized via swaync config). No -i flag → no
# small icon on the left, just the thumbnail and text.
# `default` action fires on body click → open in image viewer.
action=$(notify-send -t 5000 \
    -h "string:x-canonical-private-synchronous:screenshot" \
    -h "string:image-path:$path" \
    --action="default=Preview" \
    " " "" \
    2>/dev/null) || action=""

case "$action" in
    default) setsid -f xdg-open "$path" >/dev/null 2>&1 || true ;;
esac
