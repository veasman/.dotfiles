#!/usr/bin/env bash
set -euo pipefail

MULTI=0
if [[ "${1:-}" == "--multi" ]]; then MULTI=1; fi

pane_path="$(tmux display-message -p "#{pane_current_path}")"
session="$(tmux display-message -p "#{session_name}")"

# Ensure run window exists
ensure_run_window() {
  if ! tmux list-windows -t "$session" -F "#{window_name}" | grep -qx "run"; then
    tmux new-window -t "$session" -n run -c "$pane_path"
  fi
}

# Create extra window once, after first run starts
ensure_extra_window_once() {
  local started
  started="$(tmux show-options -t "$session" -qv "@runner_started" || true)"
  if [[ -z "$started" ]]; then
    tmux set-option -t "$session" -q "@runner_started" "1"
    if ! tmux list-windows -t "$session" -F "#{window_name}" | grep -qx "extra"; then
      tmux new-window -t "$session" -n extra -c "$pane_path"
    fi
  fi
}

# --- Command discovery helpers ---

has_file() { [[ -f "$pane_path/$1" ]]; }
has_any() { for f in "$@"; do [[ -f "$pane_path/$f" ]] && return 0; done; return 1; }

make_targets() {
  has_file "Makefile" || return 0
  # Extract simple targets, ignore pattern rules and special targets
  awk -F: '
    /^[a-zA-Z0-9_.-]+:/ && $1 !~ /^(\.|%)/ {
      t=$1
      if (t != "PHONY") print t
    }
  ' "$pane_path/Makefile" | sort -u
}

compose_files() {
  local out=()
  for f in "compose.yml" "docker-compose.yml"; do
    [[ -f "$pane_path/$f" ]] && out+=("$f")
  done
  # env variants (docker-compose.dev.yml, compose.prod.yml, etc.)
  while IFS= read -r f; do out+=("$f"); done < <(ls -1 "$pane_path"/docker-compose.*.yml 2>/dev/null | xargs -n1 basename 2>/dev/null || true)
  while IFS= read -r f; do out+=("$f"); done < <(ls -1 "$pane_path"/compose.*.yml 2>/dev/null | xargs -n1 basename 2>/dev/null || true)
  printf '%s\n' "${out[@]}" | awk 'NF' | sort -u
}

dockerfile_present() {
  has_any "Dockerfile" "Dockerfile.dev" "Dockerfile.local"
}

pkg_scripts() {
  has_file "package.json" || return 0
  command -v jq >/dev/null 2>&1 || return 0
  jq -r '.scripts // {} | keys[]' "$pane_path/package.json" 2>/dev/null | awk 'NF' | sort
}

# priority ordering for Makefile targets
make_target_priority() {
  case "$1" in
    dev) echo "00:$1" ;;
    up) echo "01:$1" ;;
    run) echo "02:$1" ;;
    start) echo "03:$1" ;;
    test) echo "04:$1" ;;
    *) echo "50:$1" ;;
  esac
}

build_menu() {
  local items=()

  # 1) Makefile
  if has_file "Makefile"; then
    while IFS= read -r t; do
      items+=("make $t")
    done < <(make_targets | awk 'NF' | while read -r t; do make_target_priority "$t"; done | sort | cut -d: -f2-)
  fi

  # 2) Compose
  local cfiles=()
  while IFS= read -r f; do [[ -n "$f" ]] && cfiles+=("$f"); done < <(compose_files)
  if [[ "${#cfiles[@]}" -gt 0 ]]; then
    # Prefer base file if present; still list all
    for f in "${cfiles[@]}"; do
      items+=("docker compose -f $f up")
      items+=("docker compose -f $f up --build")
      items+=("docker compose -f $f down")
    done
  fi

  # 3) Dockerfile
  if dockerfile_present; then
    items+=("docker build -t $(basename "$pane_path") .")
  fi

  # 4) Language markers
  if has_file "package.json"; then
    if command -v jq >/dev/null 2>&1; then
      while IFS= read -r s; do
        items+=("npm run $s")
      done < <(pkg_scripts)
    else
      items+=("npm run dev")
      items+=("npm start")
    fi
  fi

  if has_file "go.mod"; then
    items+=("go test ./... -count=1")
    items+=("go test ./...")
  fi

  if has_file "Cargo.toml"; then
    items+=("cargo run")
    items+=("cargo test")
  fi

  if has_any "pyproject.toml" "requirements.txt"; then
    items+=("python -m pytest")
  fi

  # de-dup and print
  printf '%s\n' "${items[@]}" | awk 'NF' | sort -u
}

pick_commands() {
  local menu
  menu="$(build_menu)"
  [[ -n "$menu" ]] || menu="echo 'No detected commands. Type what you want.'"

  if [[ "$MULTI" -eq 1 ]]; then
    printf '%s\n' "$menu" | fzf -m --prompt="run (multi)> "
  else
    printf '%s\n' "$menu" | fzf --prompt="run> "
  fi
}

run_single() {
  local cmd="$1"
  ensure_run_window
  ensure_extra_window_once
  tmux select-window -t "$session:run"
  tmux send-keys -t "$session:run" "cd \"$pane_path\" && $cmd" C-m
}

run_multi() {
  ensure_run_window
  ensure_extra_window_once
  tmux select-window -t "$session:run"

  local first=1
  local idx=0
  while IFS= read -r cmd; do
    [[ -n "$cmd" ]] || continue
    if [[ "$first" -eq 1 ]]; then
      tmux select-pane -t "$session:run".0
      tmux send-keys -t "$session:run".0 "cd \"$pane_path\" && $cmd" C-m
      first=0
    else
      # Split vertically into a new pane and run
      tmux split-window -t "$session:run" -v -c "$pane_path"
      idx=$((idx+1))
      tmux send-keys -t "$session:run".$idx "cd \"$pane_path\" && $cmd" C-m
    fi
  done
  tmux select-layout -t "$session:run" tiled >/dev/null 2>&1 || true
}

selected="$(pick_commands || true)"
[[ -n "${selected:-}" ]] || exit 0

if [[ "$MULTI" -eq 1 ]]; then
  run_multi <<< "$selected"
else
  run_single "$selected"
fi
