#!/usr/bin/env bash
set -euo pipefail

REPOS_DIR="${HOME}/repos"
DOTFILES_DIR="${HOME}/.dotfiles"

build_choices() {
    [[ -d "${DOTFILES_DIR}" ]] && echo "${DOTFILES_DIR}"

    [[ -d "${REPOS_DIR}" ]] || return 0
    while IFS= read -r p; do
        if [[ -d "$p" ]]; then
            echo "$p"
        elif [[ -L "$p" ]]; then
            resolved="$(readlink -f "$p" 2>/dev/null || true)"
            [[ -n "${resolved}" && -d "${resolved}" ]] && echo "$p"
        fi
    done < <(find "${REPOS_DIR}" -mindepth 1 -maxdepth 1 \( -type d -o -type l \) -print 2>/dev/null | sort)
}

find_launch_script() {
    local root="$1"
    local f="${root}/.mux/launch.sh"
    [[ -f "$f" ]] && echo "$f" && return 0
    return 1
}

find_python_venv() {
    local root="$1"
    local candidate

    for candidate in ".venv" "venv" "env"; do
        if [[ -f "${root}/${candidate}/bin/activate" ]]; then
            echo "${root}/${candidate}"
            return 0
        fi
    done

    return 1
}

selected=""
if [[ $# -eq 1 ]]; then
    selected="$1"
else
    selected="$(build_choices | fzf --prompt="Project > " || true)"
fi

[[ -n "${selected}" ]] || exit 0

# symlinks need some love too
if [[ ! -d "${selected}" && ! ( -L "${selected}" && -d "$(readlink -f "${selected}" 2>/dev/null || true)" ) ]]; then
    echo "Not a directory (or symlink to directory): ${selected}" >&2
    exit 1
fi

project_root="${selected}"

# tmux is gay and can't handle their periods
selected_name="$(basename "${project_root}" | tr '. ' '__' | tr -cd '[:alnum:]_-' )"
[[ -n "${selected_name}" ]] || selected_name="session"

launch_script="$(find_launch_script "${project_root}" || true)"
python_venv="$(find_python_venv "${project_root}" || true)"

shell_prefix='cd "$1"'
if [[ -n "${python_venv}" ]]; then
    shell_prefix+='; if [[ -f "$2/bin/activate" ]]; then source "$2/bin/activate"; else echo "Warning: Python venv not found: $2" >&2; fi'
fi

if ! tmux has-session -t "${selected_name}" 2>/dev/null; then
    tmux new-session -d -s "${selected_name}" -c "${project_root}" \
        bash -lc "${shell_prefix}; exec nvim ." bash "${project_root}" "${python_venv}"

    tmux new-window -t "${selected_name}:" -c "${project_root}" \
        bash -lc "${shell_prefix}; exec \$SHELL -l" bash "${project_root}" "${python_venv}"

    if [[ -n "${launch_script}" ]]; then
        tmux new-window -t "${selected_name}:" -n "run" -c "${project_root}" \
            bash -lc "${shell_prefix}; if [[ -x ./.mux/launch.sh ]]; then ./.mux/launch.sh; else bash ./.mux/launch.sh; fi; exec \$SHELL -l" bash "${project_root}" "${python_venv}"
    fi

    tmux select-window -t "${selected_name}:1" 2>/dev/null || true
fi

if [[ -z "${TMUX:-}" ]]; then
    tmux attach-session -t "${selected_name}"
else
    tmux switch-client -t "${selected_name}"
fi
